# NAKSHATRA-KAVACH — Environment Variables Template
# Copy to .env and fill values. Never commit .env to git.

# ── Flask ──────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-before-production

# ── Logging ────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── SocketIO ───────────────────────────────────────────────────
# eventlet | gevent | threading
SOCKETIO_ASYNC_MODE=eventlet

# ── CORS (comma-separated origins) ────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── HTTP Request Settings ──────────────────────────────────────
REQUEST_TIMEOUT_S=10
MAX_RETRIES=3

# ── Groq LLM (Layer 6 only — not used by Layer 1) ─────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
