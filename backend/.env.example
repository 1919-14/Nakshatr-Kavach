# NAKSHATRA-KAVACH — Backend environment
# Copy to backend/.env and adjust.

PORT=5000
HOST=0.0.0.0
FLASK_ENV=development

# MySQL (recommended). Example:
# DATABASE_URL=mysql+pymysql://nakshatra:yourpassword@127.0.0.1:3306/nakshatra_kavach
# Create database: CREATE DATABASE nakshatra_kavach CHARACTER SET utf8mb4;
DATABASE_URL=mysql+pymysql://nakshatra:nakshatra@127.0.0.1:3306/nakshatra_kavach

# Fallback if DATABASE_URL unset (dev only):
# DATABASE_PATH=nakshatra_kavach.db

INGESTION_INTERVAL_SECONDS=60

# NASA DONKI (optional; DEMO_KEY rate-limited)
NASA_API_KEY=DEMO_KEY

# Groq — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

LOG_LEVEL=INFO
